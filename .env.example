# Flask
SECRET_KEY=change-me-to-a-random-string

# Database
DATABASE_PATH=steam_trader.db

# Steam Market
STEAM_CURRENCY=29
STEAM_COUNTRY=HK
STEAM_REQUEST_INTERVAL=1.5

# SMTP Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
MAIL_FROM=your-email@gmail.com

# Subscription
SUBSCRIPTION_DAYS=30
DEFAULT_THRESHOLD=0.10

# Scheduler (UTC)
DAILY_PUSH_HOUR=10
DAILY_PUSH_MINUTE=0
