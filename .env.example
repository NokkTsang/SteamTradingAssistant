# Flask
SECRET_KEY=change-me-to-a-random-string

# Database
# Railway injects DATABASE_URL automatically for PostgreSQL.
# Leave blank to use SQLite locally.
DATABASE_URL=
DATABASE_PATH=/tmp/steam_trader.db

# Email — Resend HTTP API (production, bypasses SMTP port blocks)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
MAIL_FROM=onboarding@resend.dev

# Email — SMTP fallback (local dev only)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_USE_TLS=false
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Deployment
BASE_URL=http://localhost:5000

# Scheduler (UTC)
DAILY_PUSH_HOUR=10
DAILY_PUSH_MINUTE=0

# Subscription
SUBSCRIPTION_DAYS=30
DEFAULT_THRESHOLD=0.10
